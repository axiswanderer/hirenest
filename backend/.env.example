# ── Database ────────────────────────────────────────────────────────────────
# Local:      postgresql://postgres:yourpassword@localhost/jobportal_db
# Neon:       postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost/jobportal_db

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-at-least-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev:        http://localhost:5173,http://localhost:5174
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# Any password you choose. Used once at /admin/bootstrap to promote an account.
ADMIN_SECRET=your-secret-for-bootstrapping-admin

# ── AI Screening (optional) ───────────────────────────────────────────────────
# Leave blank to disable. The AI Screen button returns 503 when not set.
ANTHROPIC_API_KEY=
